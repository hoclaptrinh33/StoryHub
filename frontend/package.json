{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "type-check": "vue-tsc -b --noEmit",
    "lint": "npm run type-check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "build": "npm run type-check && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "chart.js": "^4.5.1",
    "lucide-vue-next": "latest",
    "pinia": "^2.3.1",
    "vue": "^3.5.32",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.6"
  }
}
