{
  "productName": "StoryHub",
  "version": "0.1.0",
  "identifier": "com.storyhub.manager",

  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "StoryHub Management",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],

    "security": {
      "csp": "default-src 'self'; img-src 'self' http://127.0.0.1:8000 https: data: blob:; connect-src 'self' http://127.0.0.1:8000 ws://127.0.0.1:8000"
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}